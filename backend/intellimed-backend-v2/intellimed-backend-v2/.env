FLASK_ENV=development
FLASK_DEBUG=1

# CORS — your Next.js dev URL
# FRONTEND_URL=http://localhost:3000
FRONTEND_URL=*

# Model weight paths — drop files here, then set the paths
# ALZHEIMER_MODEL_PATH=model_weights/alzheimer.keras
# BRAIN_TUMOR_MODEL_PATH=model_weights/brain_tumor.keras


#inside container
ALZHEIMER_MODEL_PATH=/app/model_weights/alzheimer.keras
BRAIN_TUMOR_MODEL_PATH=/app/model_weights/brain_tumor.keras

# Gemini
GEMINI_API_KEY=AIzaSyAngA6Ur4ZRnKcCZBk_wA8s4oeZmTKXUOE
GEMINI_MODEL=gemini-2.5-flash

# RAG vector store — two modes:
#   memory  → FAISS in-memory (default, no extra setup, data lost on restart)
#   chroma  → ChromaDB persisted to disk (set CHROMA_PATH below)
RAG_STORE=chroma
CHROMA_PATH=./chroma_db

